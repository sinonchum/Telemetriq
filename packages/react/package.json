{
  "name": "@telemetriq/react",
  "version": "0.1.0",
  "description": "React components and hooks for Telemetriq — high-frequency spatial time-series visualization",
  "type": "module",
  "keywords": ["telemetry", "timeseries", "visualization", "react", "canvas", "uplot", "racing", "drone"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sinonchum/Telemetriq.git",
    "directory": "packages/react"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@telemetriq/core": "workspace:*",
    "leaflet": "^1.9.4",
    "uplot": "^1.6.31"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^14.2.0",
    "@types/react": "^18.2.0",
    "jsdom": "^24.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@storybook/react": "^8.0.0",
    "@storybook/react-vite": "^8.0.0",
    "@storybook/addon-essentials": "^8.0.0",
    "storybook": "^8.0.0"
  }
}
