{
  "name": "@telemetriq/core",
  "version": "0.1.0",
  "description": "Core engine for Telemetriq — high-frequency spatial time-series visualization",
  "type": "module",
  "keywords": ["telemetry", "timeseries", "visualization", "playback", "iot", "racing", "drone"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sinonchum/Telemetriq.git",
    "directory": "packages/core"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
