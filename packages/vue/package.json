{
  "name": "@telemetriq/vue",
  "version": "0.1.0",
  "description": "Vue 3 composables for Telemetriq — high-frequency spatial time-series visualization",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "telemetry",
    "timeseries",
    "visualization",
    "vue",
    "racing",
    "drone"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sinonchum/Telemetriq.git",
    "directory": "packages/vue"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external vue",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@telemetriq/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vue": "^3.4.0"
  }
}
